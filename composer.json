{
    "name": "veltix/tax-engine",
    "description": "A Laravel TAX/VAT calculation engine",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/config": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-type-coverage": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Veltix\\TaxEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Veltix\\TaxEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Veltix\\TaxEngine\\LaravelTaxEngineServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
